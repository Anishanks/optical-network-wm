{
  "data_dir": "data_100",
  "context_length": 8,
  "batch_size": 4,
  "num_workers": 2,
  "pin_memory": true,
  "latent_dim": 128,
  "spectral_dim": 64,
  "node_hidden_dim": 128,
  "n_gnn_layers": 3,
  "n_gnn_heads": 4,
  "lp_summary_dim": 32,
  "use_spectral_conv": true,
  "encoder_type": "gnn",
  "pred_hidden_dim": 256,
  "n_pred_layers": 4,
  "n_pred_heads": 8,
  "action_emb_dim": 64,
  "pred_dropout": 0.1,
  "predictor_type": "transformer",
  "collapse_method": "variance",
  "collapse_weight": 0.1,
  "sigreg_projections": 1024,
  "lr": 0.0003,
  "weight_decay": 0.0001,
  "betas": [
    0.9,
    0.999
  ],
  "grad_clip": 1.0,
  "n_epochs": 3,
  "warmup_epochs": 3,
  "min_lr": 1e-06,
  "log_every": 20,
  "eval_every": 1,
  "save_every": 5,
  "output_dir": "checkpoints",
  "run_name": "smoke",
  "device": "cpu"
}